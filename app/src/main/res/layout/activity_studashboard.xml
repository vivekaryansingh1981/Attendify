<?xml version="1.0" encoding="utf-8"?>
<androidx.constraintlayout.widget.ConstraintLayout
    xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    xmlns:tools="http://schemas.android.com/tools"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="#4CB5C3"
    android:fitsSystemWindows="true">

    <View
        android:layout_width="match_parent"
        android:layout_height="0dp"
        android:background="#F8FAFC"
        app:layout_constraintTop_toBottomOf="@id/header_bg"
        app:layout_constraintBottom_toBottomOf="parent"/>

    <View
        android:id="@+id/header_bg"
        android:layout_width="match_parent"
        android:layout_height="195dp"
        android:background="#4CB5C3"
        app:layout_constraintTop_toTopOf="parent" />

    <TextView
        android:id="@+id/tv_welcome_name"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:layout_marginStart="24dp"
        android:layout_marginTop="16dp"
        android:text="Hi, Student!"
        android:textColor="#FFFFFF"
        android:textSize="26sp"
        android:textStyle="bold"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintTop_toTopOf="parent" />

    <ImageView
        android:id="@+id/btn_logout_icon"
        android:layout_width="30dp"
        android:layout_height="30dp"
        android:src="@drawable/ic_logout"
        app:tint="#FFFFFF"
        android:layout_marginEnd="20dp"
        app:layout_constraintEnd_toEndOf="parent"
        app:layout_constraintTop_toTopOf="@id/tv_welcome_name"
        app:layout_constraintBottom_toBottomOf="@id/tv_welcome_name"/>

    <ImageView
        android:id="@+id/btn_notification"
        android:layout_width="30dp"
        android:layout_height="30dp"
        android:src="@android:drawable/ic_popup_reminder"
        app:tint="#FFFFFF"
        android:layout_marginEnd="16dp"
        app:layout_constraintEnd_toStartOf="@id/btn_logout_icon"
        app:layout_constraintTop_toTopOf="@id/tv_welcome_name"
        app:layout_constraintBottom_toBottomOf="@id/tv_welcome_name"/>

    <androidx.cardview.widget.CardView
        android:id="@+id/card_attendance"
        android:layout_width="match_parent"
        android:layout_height="190dp"
        android:layout_marginStart="24dp"
        android:layout_marginEnd="24dp"
        android:layout_marginTop="24dp"
        app:cardCornerRadius="20dp"
        app:cardElevation="8dp"
        app:cardBackgroundColor="#FFFFFF"
        android:clickable="true"
        android:focusable="true"
        android:foreground="?android:attr/selectableItemBackground"
        app:layout_constraintTop_toBottomOf="@id/tv_welcome_name">

        <androidx.constraintlayout.widget.ConstraintLayout
            android:layout_width="match_parent"
            android:layout_height="match_parent">

            <TextView
                android:id="@+id/tv_att_title"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="Overall Attendance"
                android:textSize="18sp"
                android:textStyle="bold"
                android:textColor="#333333"
                android:layout_marginTop="20dp"
                app:layout_constraintTop_toTopOf="parent"
                app:layout_constraintStart_toStartOf="parent"
                app:layout_constraintEnd_toEndOf="parent" />

            <ProgressBar
                android:id="@+id/progress_attendance"
                style="?android:attr/progressBarStyleHorizontal"
                android:layout_width="100dp"
                android:layout_height="100dp"
                android:indeterminate="false"
                android:progressDrawable="@drawable/circular_progress"
                android:progress="0"
                android:max="100"
                android:layout_marginTop="10dp"
                app:layout_constraintTop_toBottomOf="@id/tv_att_title"
                app:layout_constraintStart_toStartOf="parent"
                app:layout_constraintEnd_toEndOf="parent" />

            <TextView
                android:id="@+id/tv_attendance_percentage"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="--%"
                android:textSize="28sp"
                android:textStyle="bold"
                android:textColor="#000000"
                app:layout_constraintTop_toTopOf="@id/progress_attendance"
                app:layout_constraintBottom_toBottomOf="@id/progress_attendance"
                app:layout_constraintStart_toStartOf="@id/progress_attendance"
                app:layout_constraintEnd_toEndOf="@id/progress_attendance" />

            <TextView
                android:id="@+id/tv_click_hint"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="Click To View Detailed Attendance!"
                android:textSize="14sp"
                android:textColor="#000000"
                android:layout_marginTop="8dp"
                app:layout_constraintTop_toBottomOf="@id/progress_attendance"
                app:layout_constraintStart_toStartOf="parent"
                app:layout_constraintEnd_toEndOf="parent" />

        </androidx.constraintlayout.widget.ConstraintLayout>
    </androidx.cardview.widget.CardView>

    <TextView
        android:id="@+id/tv_features"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:text="Available Features"
        android:textSize="18sp"
        android:textStyle="bold"
        android:textColor="#0F172A"
        android:layout_marginStart="24dp"
        android:layout_marginTop="20dp"
        app:layout_constraintTop_toBottomOf="@id/card_attendance"
        app:layout_constraintStart_toStartOf="parent"/>

    <GridLayout
        android:id="@+id/grid_menu"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:columnCount="2"
        android:rowCount="2"
        android:alignmentMode="alignMargins"
        android:layout_marginTop="10dp"
        android:layout_marginStart="14dp"
        android:layout_marginEnd="14dp"
        app:layout_constraintTop_toBottomOf="@id/tv_features">

        <LinearLayout
            android:layout_width="0dp"
            android:layout_height="90dp"
            android:layout_columnWeight="1"
            android:layout_margin="8dp"
            android:background="@drawable/ripple_select"
            android:backgroundTint="#6FBCC7"
            android:orientation="vertical"
            android:gravity="center"
            android:elevation="4dp">
            <ImageView
                android:layout_width="30dp"
                android:layout_height="30dp"
                android:src="@android:drawable/ic_menu_agenda"
                app:tint="#FFF"/>
            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="Notice Board"
                android:textColor="#FFF"
                android:textSize="12sp"
                android:textStyle="bold"
                android:gravity="center"/>
        </LinearLayout>

        <LinearLayout
            android:layout_width="0dp"
            android:layout_height="90dp"
            android:layout_columnWeight="1"
            android:layout_margin="8dp"
            android:background="@drawable/ripple_select"
            android:backgroundTint="#6FBCC7"
            android:orientation="vertical"
            android:gravity="center"
            android:elevation="4dp">
            <ImageView
                android:layout_width="30dp"
                android:layout_height="30dp"
                android:src="@android:drawable/ic_menu_my_calendar"/>
            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="Timetable"
                android:textColor="#FFF"
                android:textSize="12sp"
                android:textStyle="bold"/>
        </LinearLayout>

        <LinearLayout
            android:layout_width="0dp"
            android:layout_height="90dp"
            android:layout_columnWeight="1"
            android:layout_margin="8dp"
            android:background="@drawable/ripple_select"
            android:backgroundTint="#6FBCC7"
            android:orientation="vertical"
            android:gravity="center"
            android:elevation="4dp">
            <ImageView
                android:layout_width="30dp"
                android:layout_height="30dp"
                android:src="@android:drawable/ic_menu_today"/>
            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="Calendar"
                android:textColor="#FFF"
                android:textSize="12sp"
                android:textStyle="bold"/>
        </LinearLayout>

        <LinearLayout
            android:layout_width="0dp"
            android:layout_height="90dp"
            android:layout_columnWeight="1"
            android:layout_margin="8dp"
            android:background="@drawable/ripple_select"
            android:backgroundTint="#6FBCC7"
            android:orientation="vertical"
            android:gravity="center"
            android:elevation="4dp">
            <ImageView
                android:layout_width="30dp"
                android:layout_height="30dp"
                android:src="@android:drawable/ic_menu_sort_by_size"
                app:tint="#FFF"/>
            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="Unit Test Marks"
                android:textColor="#FFF"
                android:textSize="12sp"
                android:textStyle="bold"/>
        </LinearLayout>
    </GridLayout>

    <TextView
        android:id="@+id/tv_upcoming"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:text="Upcoming Classes"
        android:textSize="18sp"
        android:textStyle="bold"
        android:textColor="#0F172A"
        android:layout_marginStart="24dp"
        android:layout_marginTop="16dp"
        app:layout_constraintTop_toBottomOf="@id/grid_menu"
        app:layout_constraintStart_toStartOf="parent"/>

    <TextView
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:text="See all"
        android:textColor="#4CB5C3"
        android:textStyle="bold"
        android:layout_marginEnd="24dp"
        app:layout_constraintBottom_toBottomOf="@id/tv_upcoming"
        app:layout_constraintEnd_toEndOf="parent"/>

    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="vertical"
        android:paddingStart="24dp"
        android:layout_marginTop="10dp"
        app:layout_constraintTop_toBottomOf="@id/tv_upcoming">
        <TextView
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="10:00 AM - Math"
            android:textSize="16sp"
            android:textStyle="bold"
            android:textColor="#333"/>
    </LinearLayout>

    <com.google.android.material.bottomnavigation.BottomNavigationView
        android:id="@+id/bottom_nav"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:background="#FFFFFF"
        app:menu="@menu/bottom_menu_placeholder"
        app:layout_constraintBottom_toBottomOf="parent"/>

</androidx.constraintlayout.widget.ConstraintLayout>