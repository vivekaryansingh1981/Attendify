<?xml version="1.0" encoding="utf-8"?>
<androidx.cardview.widget.CardView
    xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="wrap_content"
    android:layout_marginBottom="16dp"
    app:cardCornerRadius="12dp"
    app:cardElevation="3dp"
    app:cardBackgroundColor="#FFFFFF">

    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="vertical"
        android:padding="16dp">

        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="horizontal"
            android:gravity="center_vertical">

            <TextView
                android:id="@+id/tv_notice_title"
                android:layout_width="0dp"
                android:layout_height="wrap_content"
                android:layout_weight="1"
                android:text="Parent Meeting"
                android:textSize="18sp"
                android:textStyle="bold"
                android:textColor="#0C7779"/>

            <TextView
                android:id="@+id/tv_notice_date"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="12 Oct 2026"
                android:textSize="12sp"
                android:textColor="#9E9E9E"/>
        </LinearLayout>

        <TextView
            android:id="@+id/tv_notice_desc"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:text="Notice description goes here..."
            android:textSize="14sp"
            android:textColor="#424242"
            android:layout_marginTop="8dp"/>

        <TextView
            android:id="@+id/tv_notice_author"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:text="Posted by: Faculty"
            android:textSize="12sp"
            android:textColor="#757575"
            android:layout_marginTop="12dp"
            android:textStyle="italic"
            android:gravity="end"/>
    </LinearLayout>

</androidx.cardview.widget.CardView>