<?xml version="1.0" encoding="utf-8"?>
<manifest xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:tools="http://schemas.android.com/tools">
    <uses-permission android:name="android.permission.INTERNET"/>
    <uses-permission android:name="android.permission.POST_NOTIFICATIONS" />

    <application
        android:allowBackup="true"
        android:dataExtractionRules="@xml/data_extraction_rules"
        android:fullBackupContent="@xml/backup_rules"
        android:icon="@mipmap/app"
        android:label="@string/app_name"
        android:roundIcon="@mipmap/app"
        android:supportsRtl="true"
        android:theme="@style/Theme.Attendify">

        <activity
            android:name="com.codingbros.attendify.SplashActivity"
            android:exported="true">
            <intent-filter>
                <action android:name="android.intent.action.MAIN" />
                <category android:name="android.intent.category.LAUNCHER" />
            </intent-filter>
        </activity>
        <activity android:name=".NoticeBoardActivity" />
        <activity android:name=".AcademicCalendarActivity" />
        <activity android:name=".RoleSelectionActivity"/>
        <activity android:name=".ParentLoginActivity"/>
        <activity android:name=".StudentLoginActivity"/>
        <activity android:name=".FacultyLoginActivity"/>
        <activity android:name=".NotificationActivity"/>
        <activity android:name=".StudashboardActivity"/>
        <activity android:name=".FacultydashboardActivity"/>
        <activity android:name=".EditTimetableActivity"/>
        <activity android:name=".StatusActivity"/>
        <activity android:name=".MarkAttendanceActivity"/>
        <activity android:name=".StudentListActivity"/>
        <activity android:name=".EnterMarksActivity" />
        <activity android:name=".StudentMarksActivity" />
        <activity android:name=".ParentDashboardActivity" />
        <activity android:name=".StudentMarksSubjectActivity" />
        <activity android:name=".StudentMarksResultActivity" />
        <activity android:name=".StudentAttendanceActivity" />
        <activity android:name=".StudentAttendanceDetailActivity" />

    </application>

</manifest>
